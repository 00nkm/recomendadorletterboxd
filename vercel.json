{
  "buildCommand": "pnpm build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/sync-start",
      "destination": "/api/app.py"
    },
    {
      "source": "/sync-status/:path*",
      "destination": "/api/app.py"
    },
    {
      "source": "/recommendations/:path*",
      "destination": "/api/app.py"
    },
    {
      "source": "/enrich",
      "destination": "/api/app.py"
    },
    {
      "source": "/feedback",
      "destination": "/api/app.py"
    }
  ]
}
